# Google OAuth Configuration
# Get these values from https://console.cloud.google.com/
# 1. Create a new OAuth 2.0 Client ID of type "Web application"
# 2. Add http://localhost:3000/api/auth/google-callback to Authorized redirect URIs for development
# 3. For production, add your actual domain

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google-callback

# Database Configuration (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_NAME=pagebuilder

# Backend URL
BACKEND_URL=http://localhost:3000/
